# ==================================================
# 🧩 SPRING BOOT / MAVEN PROJECT .gitignore
# ==================================================

# Maven target directory
/target/
/out/

# Gradle build directories (if you ever use Gradle)
/build/
/.gradle/

# IDE Specific files
# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/

# VS Code
.vscode/

# MacOS & Windows junk files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment and config
.env
*.env
application-*.yml
application-*.properties

# Generated files or uploads
uploads/
tmp/
*.tmp

# AWS or secret keys (if mistakenly generated)
*.pem
*.key

# Node / frontend leftovers (if fullstack)
node_modules/
dist/

compiler.xml